# E2E Test Credentials
# Copy this file to .env.e2e and customize, OR set these as GitHub Actions Secrets in CI/CD.
# When not set, the E2E tests fall back to the default values shown below (local dev only).

# Admin account (must exist in the target environment)
E2E_ADMIN_EMAIL=admin@learninghub.com
E2E_ADMIN_PASSWORD=AdminPass123!

# Lecturer test account
E2E_LECTURER_EMAIL=e2e_lecturer@test.com
E2E_LECTURER_PASSWORD=TestPass123!

# Student test account
E2E_STUDENT_EMAIL=e2e_student@test.com
E2E_STUDENT_PASSWORD=TestPass123!
