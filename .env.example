# PostgreSQL
DB_USER=ai_hub_user
DB_PASSWORD=your_secure_password # CHANGE THIS to a strong, unique password
DB_NAME=ai_learning_hub_db
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# Gemini (Primary Model - Multimodal)
GEMINI_API_KEY=your_gemini_api_key

# Groq (Fast Model - Intent Classification)
GROQ_API_KEY=your_groq_api_key

# Qdrant (Vector Database)
QDRANT_HOST=vector-db
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Redis (Task Queue)
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO (S3-compatible Storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123 # CHANGE THIS to a strong, unique password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_NAME=documents-bucket
MINIO_SECURE=false

# Application Settings
SECRET_KEY=your_secret_key_for_jwt # GENERATE A STRONG KEY: e.g., using `openssl rand -hex 32` or similar
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Application
APP_NAME=Multimodal AI Learning Hub
DEBUG=true
LOG_LEVEL=INFO
